str(df1)
data <- df1 %>%
drop_na(Gender, LeaverStatus)
summary(data)
str(df1)
str(data)
tabla_cruzada <- table(data$Country, data$Leaver_Status)
tabla_cruzada <- table(data$Country, data$LeaverStatus)
tabla_cruzada <- table(data$Country, data$LeaverStatus)
knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(readxl)
tabla_cruzada <- table(data$Country, data$LeaverStatus)
cat("\n--- FRECUENCIAS OBSERVADAS (Lo que realmente pasó) ---\n")
print(tabla_cruzada)
tabla_cruzada <- table(
"País" = data$Country,
"Estado_Rotación (0=Retenido, 1=Salida)" = data$LeaverStatus
)
# 2. (Opcional pero recomendado para HR) Añadir una fila y columna de "Totales"
tabla_con_totales <- addmargins(tabla_cruzada)
# 3. Imprimir en consola para que la veas tú mientras programas
cat("\n--- FRECUENCIAS OBSERVADAS ---\n")
print(tabla_con_totales)
# 4. Crear la versión "bonita" para el reporte HTML final
# Usamos kable (de la librería knitr que ya tienes instalada)
knitr::kable(tabla_con_totales,
caption = "Frecuencia de Rotación de Empleados por País")
# Opcional: Mostrar una advertencia en consola si hay problemas con tamaños de muestra
if(any(test_chi$expected < 5)) {
warning("Atención HR: Hay subgrupos con frecuencias esperadas menores a 5. El resultado del test podría no ser completamente fiable.")
}
# 3. Calcular las Frecuencias Esperadas
# Guardamos el test en un objeto para extraer los valores esperados
test_chi <- chisq.test(tabla_cruzada)
cat("\n--- FRECUENCIAS ESPERADAS (Lo que pasaría si la rotación fuera igual en todos los países) ---\n")
print(round(test_chi$expected, 2)) # Redondeamos a 2 decimales para facilitar la lectura
# Mostrar el resultado del test de independencia de Chi-cuadrado
cat("\n--- RESULTADO DEL TEST CHI-CUADRADO ---\n")
print(test_chi)
# Opcional: Mostrar una advertencia en consola si hay problemas con tamaños de muestra
if(any(test_chi$expected < 5)) {
warning("Atención HR: Hay subgrupos con frecuencias esperadas menores a 5. El resultado del test podría no ser completamente fiable.")
}
# 1. Asegurarnos de tener el test calculado
test_chi <- chisq.test(tabla_cruzada)
# 2. Crear una tabla completa combinando las columnas del test
# La columna 1 es "Se quedan" (0) y la columna 2 es "Se van" (1)
tabla_completa <- data.frame(
País = rownames(test_chi$observed),
# Datos REALES (Lo que de verdad pasó)
Stay_obv = test_chi$observed[, 1],
Leave_obv    = test_chi$observed[, 2],
# Datos ESPERADOS (Lo que la estadística predecía si todo fuera equitativo)
Stay_exp = round(test_chi$expected[, 1], 1),
Leave_exp    = round(test_chi$expected[, 2], 1)
)
# 3. Mostrar la tabla con un diseño elegante para tu reporte HTML
knitr::kable(tabla_completa,
row.names = FALSE,
caption = "Comparativa Completa: Retención y Salidas (Reales vs Esperadas) por País")
tabla_completa$Dif_Leave <- tabla_completa$Leave_obv - tabla_completa$Leave_exp
# 1. Asegurarnos de tener el test calculado
test_chi <- chisq.test(tabla_cruzada)
# 2. Crear una tabla completa combinando las columnas del test
# La columna 1 es "Se quedan" (0) y la columna 2 es "Se van" (1)
tabla_completa <- data.frame(
País = rownames(test_chi$observed),
# Datos REALES (Lo que de verdad pasó)
Stay_obv = test_chi$observed[, 1],
Leave_obv    = test_chi$observed[, 2],
# Datos ESPERADOS (Lo que la estadística predecía si todo fuera equitativo)
Stay_exp = round(test_chi$expected[, 1], 1),
Leave_exp    = round(test_chi$expected[, 2], 1)
)
tabla_completa$Dif_Stay <- tabla_completa$Stay_obv - tabla_completa$Stay_exp
tabla_completa$Dif_Leave <- tabla_completa$Leave_obv - tabla_completa$Leave_exp
# 3. Mostrar la tabla con un diseño elegante para tu reporte HTML
knitr::kable(tabla_completa,
row.names = FALSE,
caption = "Comparativa Completa: Retención y Salidas (Reales vs Esperadas) por País")
# 1. Asegurarnos de tener el test calculado
test_chi <- chisq.test(tabla_cruzada)
# 2. Crear una tabla completa combinando las columnas del test
# La columna 1 es "Se quedan" (0) y la columna 2 es "Se van" (1)
tabla_completa <- data.frame(
País = rownames(test_chi$observed),
# Datos REALES (Lo que de verdad pasó)
Stay_obv = test_chi$observed[, 1],
Leave_obv    = test_chi$observed[, 2],
# Datos ESPERADOS (Lo que la estadística predecía si todo fuera equitativo)
Stay_exp = round(test_chi$expected[, 1], 1),
Leave_exp    = round(test_chi$expected[, 2], 1)
)
tabla_completa$Dif_Stay <- tabla_completa$Stay_obv - tabla_completa$Stay_exp
# 3. Mostrar la tabla con un diseño elegante para tu reporte HTML
knitr::kable(tabla_completa,
row.names = FALSE,
caption = "Comparativa Completa: Retención y Salidas (Reales vs Esperadas) por País")
# 1. Asegurarnos de tener el test calculado
test_chi <- chisq.test(tabla_cruzada)
cat("\n--- RESULTADO DEL TEST CHI-CUADRADO ---\n")
print(test_chi)
print(test_chi$expected)
# 2. Crear una tabla completa combinando las columnas del test
# La columna 1 es "Se quedan" (0) y la columna 2 es "Se van" (1)
tabla_completa <- data.frame(
País = rownames(test_chi$observed),
# Datos REALES (Lo que de verdad pasó)
Stay_obv = test_chi$observed[, 1],
Leave_obv    = test_chi$observed[, 2],
# Datos ESPERADOS (Lo que la estadística predecía si todo fuera equitativo)
Stay_exp = round(test_chi$expected[, 1], 1),
Leave_exp    = round(test_chi$expected[, 2], 1)
)
tabla_completa$Dif_Stay <- tabla_completa$Stay_obv - tabla_completa$Stay_exp
# 3. Mostrar la tabla con un diseño elegante para tu reporte HTML
knitr::kable(tabla_completa,
row.names = FALSE,
caption = "Complete Comparison: Retention and Turnover (Observed vs Expected) by Country")
