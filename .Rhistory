knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
if(!require("pacman")) install.packages("pacman")
pacman::p_load(readxl, psych, dplyr, GPArotation, scatterplot3d, modelsummary, car, this.path, huxtable)
library(readxl)
library(lm.beta)
library(readxl)
library(psych)
library(GPArotation)
# Importar el archivo (ajusta el nombre si es necesario)
file_path <- "Ch5_SURVEY_PROVIDER_ENGAGEMENT_DATA_TEAM_LEVEL.xlsx"
df <- read_excel(file_path, sheet = 1)
# Seleccionar los 9 ítems de compromiso (Eng1 a Eng9)
engagement_items <- df[, c("Eng1", "Eng2", "Eng3", "Eng4", "Eng5", "Eng6", "Eng7", "Eng8", "Eng9")]
# Ejecutar PCA con rotación varimax
# Basado en el análisis, 3 componentes suelen explicar mejor la varianza en este set
pca_result <- principal(engagement_items, nfactors = 3, rotate = "varimax")
# Deliverable: Tabla de cargas de componentes
print(pca_result$loadings, cutoff = 0.4, digits = 3)
if(!require(scatterplot3d)) install.packages("scatterplot3d")
library(scatterplot3d)
# Extraer las puntuaciones de los componentes por equipo
scores <- as.data.frame(pca_result$scores)
# Deliverable: Scatterplot 3D
scatterplot3d(scores[,1:3],
pch = 16, color = "steelblue",
main = "Espacio de Componentes de Compromiso",
xlab = "Comp 1: Org. y Propósito",
ylab = "Comp 2: Bienestar",
zlab = "Comp 3: Ética y Seguridad")
library(readxl)
library(car) # Para Levene's Test
# 1. Importar los datos
df <- read_excel("Ch5_Engagement_CASE_Group_level_data_2023.xlsx", sheet = "data")
# 2. Preparar los factores
df$LondonorNot <- factor(df$LondonorNot, levels = c(1, 2), labels = c("London", "Other"))
df$Function <- factor(df$Function, levels = c(1, 2), labels = c("Sales", "Prof. Services"))
# --- COMPARACIÓN POR UBICACIÓN ---
leveneTest(EMPsurvEngagement ~ LondonorNot, data = df) # p > 0.05: Varianzas iguales
t_loc <- t.test(EMPsurvEngagement ~ LondonorNot, data = df, var.equal = TRUE)
print(t_loc)
# --- COMPARACIÓN POR FUNCIÓN ---
leveneTest(EMPsurvEngagement ~ Function, data = df) # p > 0.05: Varianzas iguales
t_fun <- t.test(EMPsurvEngagement ~ Function, data = df, var.equal = TRUE)
print(t_fun)
# Resumen visual rápido
boxplot(EMPsurvEngagement ~ Function, data = df,
main = "Compromiso por Función", col = c("orange", "lightblue"))
library(readxl)
library(lm.beta)
library(readxl)
library(lm.beta)
# 1. Carga de datos
df <- read_excel("Ch5_Engagement_CASE_Group_level_data_2023.xlsx", sheet = "data")
# 2. Preparar variables (asegurar que sean factores donde corresponda)
df$Location <- as.factor(df$Location)
df$Function <- as.factor(df$Function)
# 3. Ejecutar el modelo de regresión múltiple
modelo <- lm(EMPsurvEngagement ~ EmpSurvSupervisor + EmployeeSurvOrgIntegrity +
GroupSize + PercentMale + UG + Location + Function, data = df)
# 4. Obtener coeficientes estandarizados
modelo_beta <- lm.beta(modelo)
# Deliverable: Resumen de la regresión
summary(modelo_beta)
knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
if(!require("pacman")) install.packages("pacman")
pacman::p_load(readxl, psych, dplyr, GPArotation, scatterplot3d, modelsummary, car, this.path, huxtable)
library(readxl)
library(psych)
library(GPArotation)
# Importar el archivo (ajusta el nombre si es necesario)
file_path <- "Ch5_SURVEY_PROVIDER_ENGAGEMENT_DATA_TEAM_LEVEL.xlsx"
df <- read_excel(file_path, sheet = 1)
head(df)
# Ejecutar PCA con rotación varimax
# Basado en el análisis, 3 componentes suelen explicar mejor la varianza en este set
pca_result <- principal(df, nfactors = 3, rotate = "varimax")
# Deliverable: Tabla de cargas de componentes
print(pca_result$loadings, cutoff = 0.4, digits = 3)
if(!require(scatterplot3d)) install.packages("scatterplot3d")
library(scatterplot3d)
# Extraer las puntuaciones de los componentes por equipo
scores <- as.data.frame(pca_result$scores)
# Deliverable: Scatterplot 3D
scatterplot3d(scores[,1:3],
pch = 16, color = "steelblue",
main = "3D Component Space (Engagement Items)",
xlab = "RC1: Loyalty",
ylab = "RC2: Well-being",
zlab = "RC3: Ethics")
