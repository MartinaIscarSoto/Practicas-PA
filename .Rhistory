knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
# Load libraries
library(readxl)
library(dplyr)
library(janitor)
# Import dataset
data <- read_excel("Databases/recruitment_applicants_2023.xlsx")
# Clean names
data <- clean_names(data)
# Check names
names(data)
names(data)
glimpse(data)
# Recode variables
# Recode variables
data <- data %>%
mutate(
gender_rec = case_when(
gender %in% c(1, "1", "F", "Female") ~ "Female",
gender %in% c(2, "2", "M", "Male") ~ "Male",
TRUE ~ "Other/Unknown"
),
ug_rec = case_when(
u_gyn %in% c(1, "1", "Y", "Yes") ~ "UG",
u_gyn %in% c(2, "2", "N", "No") ~ "Non-UG",
TRUE ~ "Unknown"
)
)
# Frequency tables
freq_gender <- tabyl(data$gender_rec)
freq_ug <- tabyl(data$ug_rec)
freq_shortlisted <- tabyl(data$shortlisted_ny)
freq_interviewed <- tabyl(data$interviewed)
freq_offered <- tabyl(data$offer_ny)
freq_accepted <- tabyl(data$accept_ny)
freq_joined <- tabyl(data$join_yn)
freq_gender
freq_ug
freq_shortlisted
freq_interviewed
freq_offered
freq_accepted
freq_joined
# Print results
# Load libraries
library(readxl)
library(dplyr)
library(janitor)
# Import dataset
df1 <- read_excel("Databases/recruitment_applicants_2023.xlsx")
# Clean names
df1 <- clean_names(df1)
# Check names
names(df1)
names(df1)
glimpse(df1)
# Recode variables
# Recode variables
df1 <- df1 %>%
mutate(
gender_rec = case_when(
gender %in% c(1, "1", "F", "Female") ~ "Female",
gender %in% c(2, "2", "M", "Male") ~ "Male",
TRUE ~ "Other/Unknown"
),
ug_rec = case_when(
u_gyn %in% c(1, "1", "Y", "Yes") ~ "UG",
u_gyn %in% c(2, "2", "N", "No") ~ "Non-UG",
TRUE ~ "Unknown"
)
)
# Frequency tables
freq_gender <- tabyl(df1$gender_rec)
freq_ug <- tabyl(df1$ug_rec)
freq_shortlisted <- tabyl(df1$shortlisted_ny)
freq_interviewed <- tabyl(df1$interviewed)
freq_offered <- tabyl(df1$offer_ny)
freq_accepted <- tabyl(df1$accept_ny)
freq_joined <- tabyl(df1$join_yn)
freq_gender
freq_ug
freq_shortlisted
freq_interviewed
freq_offered
freq_accepted
freq_joined
